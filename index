import { useState, useEffect, useCallback, useRef } from "react";

// ============================================================
// CONFIG & STORAGE
// ============================================================

const STORAGE_KEY = "kurage_v1";
const load = () => { try { return JSON.parse(localStorage.getItem(STORAGE_KEY)); } catch { return null; } };
const save = (d) => localStorage.setItem(STORAGE_KEY, JSON.stringify(d));
const todayKey = (d) => d?.debugDate || new Date().toISOString().split("T")[0];

const DECAY_RATE = 0.07; // water level drops per hour (0-1 scale), ~14h to empty
const DRINK_AMOUNT = 0.14; // each tap adds this much (roughly 7 taps to fill)

function createData() {
  return {
    waterLevel: 0.3,
    lastUpdate: Date.now(),
    history: {},
    achievedDates: [],
    totalDrinks: 0,
    streakBest: 0,
    debugDate: null,
  };
}

function getStreak(dates) {
  if (!dates.length) return 0;
  const sorted = [...dates].sort().reverse();
  const today = new Date().toISOString().split("T")[0];
  let s = 0, cd = new Date(today);
  if (!sorted.includes(today)) cd.setDate(cd.getDate() - 1);
  for (let i = 0; i < 999; i++) {
    if (sorted.includes(cd.toISOString().split("T")[0])) { s++; cd.setDate(cd.getDate() - 1); }
    else break;
  }
  return s;
}

function applyDecay(data) {
  const now = Date.now();
  const hours = (now - data.lastUpdate) / 3600000;
  const newLevel = Math.max(0, data.waterLevel - hours * DECAY_RATE);
  return { ...data, waterLevel: newLevel, lastUpdate: now };
}

function getWaterState(level) {
  if (level >= 0.9) return { id: "full", label: "きもちいい〜", glow: true };
  if (level >= 0.6) return { id: "normal", label: "すいすい〜", glow: false };
  if (level >= 0.3) return { id: "low", label: "ちょっとのどかわいた…", glow: false };
  return { id: "empty", label: "しずかです…", glow: false };
}

const MESSAGES = {
  full: ["きもちいい〜！", "ふわふわ〜♪", "水がたっぷり！", "きらきら〜✨", "ありがとう！最高〜"],
  normal: ["すいすい〜", "いいかんじ♪", "ふわ〜", "きょうもよろしくね", "おさんぽ中〜"],
  low: ["ちょっとのどかわいたな…", "お水ほしいな…", "泡がすくないよ…", "ふぅ…"],
  empty: ["しずかです…", "…", "水がすくないよ…", "だれかいる…？"],
};

const DRINK_REACTIONS = [
  "ぽこっ！うれしい！",
  "ふわぁ〜♪",
  "つめたくてきもちいい！",
  "ありがとう〜！",
  "ぷかぷか♪",
  "おみずだ〜！",
  "しあわせ〜",
  "もっとおよげる！",
];

// ============================================================
// ANIMATED JELLYFISH (pure CSS)
// ============================================================

function Jellyfish({ waterLevel, glow }) {
  const speed = waterLevel > 0.6 ? "4s" : waterLevel > 0.3 ? "6s" : "9s";
  const opacity = waterLevel > 0.3 ? 1 : 0.6;
  const scale = 0.8 + waterLevel * 0.3;
  const glowFilter = glow ? "drop-shadow(0 0 20px rgba(180,220,255,0.9)) drop-shadow(0 0 40px rgba(120,180,255,0.5))" : "drop-shadow(0 0 8px rgba(180,220,255,0.3))";

  return (
    <div style={{
      position: "absolute",
      top: `${25 - waterLevel * 10}%`,
      left: "50%",
      transform: `translateX(-50%) scale(${scale})`,
      opacity,
      filter: glowFilter,
      transition: "all 1.5s ease",
      zIndex: 10,
    }}>
      <svg width="120" height="140" viewBox="0 0 120 140">
        <defs>
          <radialGradient id="jellyGrad" cx="50%" cy="30%" r="60%">
            <stop offset="0%" stopColor={glow ? "#e8f4ff" : "#d4eaf7"} />
            <stop offset="50%" stopColor={glow ? "#a8d8ff" : "#89c4e8"} />
            <stop offset="100%" stopColor={glow ? "#6bb8f0" : "#5a9ec4"} />
          </radialGradient>
          <radialGradient id="jellyInner" cx="50%" cy="40%" r="40%">
            <stop offset="0%" stopColor="rgba(255,255,255,0.5)" />
            <stop offset="100%" stopColor="rgba(255,255,255,0)" />
          </radialGradient>
        </defs>
        <style>{`
          @keyframes jellyPulse { 0%,100%{transform:scaleX(1) scaleY(1)} 50%{transform:scaleX(1.06) scaleY(0.94)} }
          @keyframes jellyFloat { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-12px)} }
          @keyframes tentacle1 { 0%,100%{d:path("M35,70 Q30,100 25,130")} 50%{d:path("M35,70 Q40,105 30,130")} }
          @keyframes tentacle2 { 0%,100%{d:path("M60,75 Q58,105 55,135")} 50%{d:path("M60,75 Q65,108 60,135")} }
          @keyframes tentacle3 { 0%,100%{d:path("M85,70 Q90,100 95,130")} 50%{d:path("M85,70 Q80,105 90,130")} }
        `}</style>
        <g style={{ animation: `jellyFloat ${speed} ease-in-out infinite` }}>
          <g style={{ animation: `jellyPulse ${speed} ease-in-out infinite`, transformOrigin: "60px 45px" }}>
            {/* Bell */}
            <ellipse cx="60" cy="45" rx="42" ry="35" fill="url(#jellyGrad)" opacity="0.85" />
            <ellipse cx="60" cy="45" rx="36" ry="30" fill="url(#jellyInner)" />
            {/* Eyes */}
            <circle cx="48" cy="42" r="3.5" fill="#2a5070" opacity="0.7" />
            <circle cx="72" cy="42" r="3.5" fill="#2a5070" opacity="0.7" />
            <circle cx="49" cy="41" r="1.2" fill="#fff" />
            <circle cx="73" cy="41" r="1.2" fill="#fff" />
            {/* Mouth */}
            {waterLevel > 0.6 ? (
              <path d="M54,52 Q60,57 66,52" fill="none" stroke="#2a5070" strokeWidth="1.5" opacity="0.6" strokeLinecap="round" />
            ) : waterLevel > 0.3 ? (
              <ellipse cx="60" cy="53" rx="3" ry="1.5" fill="#2a5070" opacity="0.4" />
            ) : (
              <path d="M54,55 Q60,51 66,55" fill="none" stroke="#2a5070" strokeWidth="1.5" opacity="0.6" strokeLinecap="round" />
            )}
            {/* Rim */}
            <path d="M18,55 Q30,68 60,70 Q90,68 102,55" fill="none" stroke="rgba(100,180,230,0.4)" strokeWidth="2" />
          </g>
          {/* Tentacles */}
          <path d="M35,70 Q30,100 25,130" fill="none" stroke="rgba(130,195,240,0.5)" strokeWidth="2.5" strokeLinecap="round"
            style={{ animation: `tentacle1 ${parseFloat(speed) * 1.3}s ease-in-out infinite` }} />
          <path d="M45,72 Q42,98 38,125" fill="none" stroke="rgba(130,195,240,0.4)" strokeWidth="2" strokeLinecap="round"
            style={{ animation: `tentacle1 ${parseFloat(speed) * 1.5}s ease-in-out infinite 0.3s` }} />
          <path d="M60,75 Q58,105 55,135" fill="none" stroke="rgba(130,195,240,0.5)" strokeWidth="2.5" strokeLinecap="round"
            style={{ animation: `tentacle2 ${parseFloat(speed) * 1.2}s ease-in-out infinite 0.2s` }} />
          <path d="M75,72 Q78,98 82,125" fill="none" stroke="rgba(130,195,240,0.4)" strokeWidth="2" strokeLinecap="round"
            style={{ animation: `tentacle3 ${parseFloat(speed) * 1.5}s ease-in-out infinite 0.5s` }} />
          <path d="M85,70 Q90,100 95,130" fill="none" stroke="rgba(130,195,240,0.5)" strokeWidth="2.5" strokeLinecap="round"
