}

// ============================================================
// BUBBLES
// ============================================================

function Bubbles({ waterLevel }) {
  const count = waterLevel > 0.8 ? 12 : waterLevel > 0.5 ? 7 : waterLevel > 0.2 ? 3 : 1;
  return (
    <>
      <style>{`@keyframes bubbleUp{0%{transform:translateY(0) scale(1);opacity:0.7}50%{opacity:0.5}100%{transform:translateY(-200px) scale(0.3);opacity:0}}`}</style>
      {Array.from({ length: count }).map((_, i) => {
        const left = 15 + Math.random() * 70;
        const size = 4 + Math.random() * 8;
        const dur = 3 + Math.random() * 4;
        const delay = Math.random() * 5;
        return (
          <div key={i} style={{
            position: "absolute",
            bottom: `${5 + waterLevel * 10}%`,
            left: `${left}%`,
            width: size, height: size,
            borderRadius: "50%",
            background: "radial-gradient(circle at 30% 30%, rgba(255,255,255,0.8), rgba(180,220,255,0.3))",
            animation: `bubbleUp ${dur}s ease-in infinite ${delay}s`,
            zIndex: 5,
          }} />
        );
      })}
    </>
  );
}

// ============================================================
// AQUARIUM
// ============================================================

function Aquarium({ data, onDrink, reaction }) {
  const state = getWaterState(data.waterLevel);
  const waterPct = Math.max(5, data.waterLevel * 85);

  const bgTop = data.waterLevel > 0.6 ? "#0a1628" : data.waterLevel > 0.3 ? "#0d1f3c" : "#111827";
  const waterColor = state.glow ? "rgba(60,140,220,0.45)" : data.waterLevel > 0.3 ? "rgba(40,100,180,0.35)" : "rgba(30,60,100,0.25)";

  return (
    <div style={{
      position: "relative",
      width: "100%",
      height: 420,
      background: `linear-gradient(180deg, ${bgTop} 0%, #0a2a4a 100%)`,
      borderRadius: "0 0 24px 24px",
      overflow: "hidden",
      transition: "background 2s ease",
    }}>
      {/* Stars / particles at top */}
      {state.glow && (
        <style>{`@keyframes twinkle{0%,100%{opacity:0.3}50%{opacity:1}}`}</style>
      )}
      {state.glow && Array.from({ length: 8 }).map((_, i) => (
        <div key={`star${i}`} style={{
          position: "absolute",
          top: `${5 + Math.random() * 20}%`,
          left: `${10 + Math.random() * 80}%`,
          width: 3, height: 3, borderRadius: "50%",
          background: "#fff",
          animation: `twinkle ${1.5 + Math.random() * 2}s ease-in-out infinite ${Math.random() * 2}s`,
          zIndex: 2,
        }} />
      ))}

      {/* Water body */}
      <div style={{
        position: "absolute",
        bottom: 0, left: 0, right: 0,
        height: `${waterPct}%`,
        background: `linear-gradient(180deg, ${waterColor} 0%, rgba(10,40,80,0.6) 100%)`,
        transition: "height 1.5s ease, background 1.5s ease",
        zIndex: 3,
      }}>
        {/* Water surface wave */}
        <div style={{
          position: "absolute", top: -6, left: 0, right: 0, height: 12,
          background: `linear-gradient(180deg, transparent 0%, ${waterColor} 100%)`,
          borderRadius: "50% 50% 0 0",
        }} />
      </div>

      {/* Jellyfish */}
      <Jellyfish waterLevel={data.waterLevel} glow={state.glow} />

      {/* Bubbles */}
      <Bubbles waterLevel={data.waterLevel} />

      {/* Bottom sand/rocks */}
      <div style={{
        position: "absolute", bottom: 0, left: 0, right: 0, height: 30,
        background: "linear-gradient(180deg, rgba(60,80,100,0.3) 0%, rgba(40,55,70,0.6) 100%)",
        zIndex: 4,
      }} />

      {/* Reaction text */}
      {reaction && (
        <div style={{
          position: "absolute", top: "15%", left: "50%", transform: "translateX(-50%)",
          background: "rgba(255,255,255,0.15)", backdropFilter: "blur(8px)",
          borderRadius: 16, padding: "8px 18px",
          fontSize: 15, color: "#e0f0ff", fontWeight: 700,
          fontFamily: "'Zen Maru Gothic',sans-serif",
          zIndex: 20, whiteSpace: "nowrap",
          animation: "fadeInUp 0.5s ease",
        }}>
          {reaction}
        </div>
      )}

      {/* Jellyfish speech */}
      {!reaction && (
        <div style={{
          position: "absolute", bottom: "8%", left: "50%", transform: "translateX(-50%)",
          fontSize: 13, color: "rgba(200,220,240,0.7)",
          fontFamily: "'Zen Maru Gothic',sans-serif",
          zIndex: 20, whiteSpace: "nowrap",
          textShadow: "0 1px 4px rgba(0,0,0,0.5)",
        }}>
          {state.label}
        </div>
      )}

      {/* Drink button */}
      <button onClick={onDrink} style={{
        position: "absolute", bottom: 16, left: "50%", transform: "translateX(-50%)",
        background: state.glow
          ? "linear-gradient(135deg, rgba(100,200,255,0.5), rgba(60,140,220,0.5))"
          : "linear-gradient(135deg, rgba(80,160,220,0.4), rgba(40,100,180,0.4))",
        backdropFilter: "blur(12px)",
        border: "2px solid rgba(180,220,255,0.3)",
        borderRadius: 20, padding: "12px 36px",
        fontSize: 16, fontWeight: 700,
        color: "#e0f0ff",
        fontFamily: "'Zen Maru Gothic',sans-serif",
        cursor: "pointer",
        zIndex: 30,
        boxShadow: state.glow ? "0 0 20px rgba(100,180,255,0.3)" : "none",
        transition: "all 0.3s",
      }}>
        💧 飲んだ！
      </button>
    </div>
  );
}

