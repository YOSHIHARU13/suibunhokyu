// ============================================================
// MAIN APP
// ============================================================

export default function App() {
  const [data, setData] = useState(() => {
    const loaded = load();
    return loaded ? applyDecay(loaded) : null;
  });
  const [reaction, setReaction] = useState(null);
  const [showDebug, setShowDebug] = useState(false);
  const reactionTimer = useRef(null);

  // Save & decay tick
  useEffect(() => { if (data) save(data); }, [data]);
  useEffect(() => {
    const tick = setInterval(() => {
      setData(prev => prev ? applyDecay(prev) : null);
    }, 60000); // update every minute
    return () => clearInterval(tick);
  }, []);

  const handleStart = useCallback(() => setData(createData()), []);

  const handleDrink = useCallback(() => {
    if (reactionTimer.current) clearTimeout(reactionTimer.current);
    const msg = DRINK_REACTIONS[Math.floor(Math.random() * DRINK_REACTIONS.length)];
    setReaction(msg);
    reactionTimer.current = setTimeout(() => setReaction(null), 2000);

    setData(prev => {
      const d = { ...prev };
      const today = todayKey(d);
      const prevLevel = d.waterLevel;
      d.waterLevel = Math.min(1, d.waterLevel + DRINK_AMOUNT);
      d.lastUpdate = Date.now();
      d.history = { ...d.history, [today]: (d.history[today] || 0) + 1 };
      d.totalDrinks = (d.totalDrinks || 0) + 1;

      // Achievement: reaching full today
      if (prevLevel < 0.9 && d.waterLevel >= 0.9 && !d.achievedDates.includes(today)) {
        d.achievedDates = [...d.achievedDates, today];
        const streak = getStreak(d.achievedDates);
        if (streak > (d.streakBest || 0)) d.streakBest = streak;
      }
      return d;
    });
  }, []);

  const advanceDay = useCallback(() => {
    setData(prev => {
      const d = { ...prev };
      const cur = d.debugDate || new Date().toISOString().split("T")[0];
      const next = new Date(cur); next.setDate(next.getDate() + 1);
      d.debugDate = next.toISOString().split("T")[0];
      d.waterLevel = Math.max(0, d.waterLevel - 0.4);
      return d;
    });
  }, []);

  if (!data) {
    return (
      <div style={{
        minHeight: "100vh",
        background: "linear-gradient(180deg, #0a1628 0%, #0a2a4a 100%)",
        display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center",
        fontFamily: "'Zen Maru Gothic',sans-serif", padding: 24,
      }}>
        <link href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@400;700;900&display=swap" rel="stylesheet" />
        <style>{`@keyframes gentleFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}`}</style>
        <div style={{ fontSize: 80, marginBottom: 16, animation: "gentleFloat 4s ease-in-out infinite" }}>🪼</div>
        <h1 style={{ fontSize: 26, fontWeight: 900, color: "#c8e6ff", marginBottom: 4 }}>くらげすいそう</h1>
        <p style={{ fontSize: 13, color: "rgba(180,210,240,0.5)", marginBottom: 40 }}>水を飲んで、くらげを元気にしよう</p>
        <button onClick={handleStart} style={{
          background: "linear-gradient(135deg, rgba(80,160,220,0.5), rgba(40,100,180,0.5))",
          backdropFilter: "blur(12px)",
          border: "2px solid rgba(180,220,255,0.2)",
          borderRadius: 16, padding: "16px 48px",
          fontSize: 17, fontWeight: 700, color: "#c8e6ff",
          fontFamily: "'Zen Maru Gothic',sans-serif",
          cursor: "pointer",
        }}>
          💧 はじめる
        </button>
      </div>
    );
  }

  return (
    <div style={{
      minHeight: "100vh",
      background: "linear-gradient(180deg, #0a1628 0%, #0e2240 50%, #0a1628 100%)",
      fontFamily: "'Zen Maru Gothic',sans-serif", color: "#c8e6ff",
    }}>
      <link href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@400;700;900&display=swap" rel="stylesheet" />
      <style>{`@keyframes fadeInUp{from{opacity:0;transform:translateX(-50%) translateY(10px)}to{opacity:1;transform:translateX(-50%) translateY(0)}}`}</style>

      {/* Header */}
      <div style={{
        padding: "12px 16px",
        display: "flex", justifyContent: "space-between", alignItems: "center",
        position: "relative", zIndex: 40,
      }}>
        <div style={{ fontSize: 16, fontWeight: 900 }}>🪼 くらげすいそう</div>
        <div style={{ textAlign: "right" }}>
          {data.debugDate && <div style={{ fontSize: 10, color: "#f87171" }}>🐛 {data.debugDate}</div>}
        </div>
      </div>

      {/* Aquarium */}
      <Aquarium data={data} onDrink={handleDrink} reaction={reaction} />

      {/* Stats */}
      <StatsPanel data={data} />

      {/* Debug */}
      <div style={{ textAlign: "center", padding: "20px 0 60px" }}>
        <button style={{
          background: "transparent", border: "1px solid rgba(255,255,255,0.1)",
          borderRadius: 8, padding: "6px 14px", fontSize: 11,
          color: "rgba(180,210,240,0.3)", cursor: "pointer",
          fontFamily: "'Zen Maru Gothic',sans-serif",
        }} onClick={() => setShowDebug(!showDebug)}>
          🐛 デバッグ {showDebug ? "▲" : "▼"}
        </button>
        {showDebug && (
          <div style={{ display: "flex", gap: 8, justifyContent: "center", flexWrap: "wrap", marginTop: 8 }}>
            <button style={{ background: "rgba(100,180,255,0.2)", border: "none", borderRadius: 8, padding: "6px 12px", fontSize: 11, color: "#7dd3fc", cursor: "pointer", fontFamily: "'Zen Maru Gothic',sans-serif" }} onClick={advanceDay}>📅 1日進める</button>
            <button style={{ background: "rgba(100,180,255,0.2)", border: "none", borderRadius: 8, padding: "6px 12px", fontSize: 11, color: "#7dd3fc", cursor: "pointer", fontFamily: "'Zen Maru Gothic',sans-serif" }} onClick={() => setData(p => ({ ...p, debugDate: null }))}>🔄 日付リセ</button>
            <button style={{ background: "rgba(255,100,100,0.2)", border: "none", borderRadius: 8, padding: "6px 12px", fontSize: 11, color: "#f87171", cursor: "pointer", fontFamily: "'Zen Maru Gothic',sans-serif" }} onClick={() => { if (confirm("全データ削除？")) { localStorage.removeItem(STORAGE_KEY); setData(null); } }}>🗑️ 全削除</button>
          </div>
        )}
      </div>
    </div>
  );
}
